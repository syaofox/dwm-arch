! dwm 窗口颜色 - 未选中，无客户端
dwm.col_norm_fg:        BLACK
dwm.col_norm_bg:        BG
dwm.col_norm_border:    BORDER

! dwm 窗口颜色 - 选中，无客户端
dwm.col_sel_fg:         FG
dwm.col_sel_bg:         SEL_BG
dwm.col_sel_border:     MAGENTA

! dwm 窗口颜色 - 未选中，有客户端
dwm.col_occ_fg:         FG
dwm.col_occ_bg:         BG
dwm.col_occ_border:     BORDER

! dwm 窗口颜色 - 选中，有客户端
dwm.col_selocc_fg:      FG
dwm.col_selocc_bg:      SEL_BG
dwm.col_selocc_border:  MAGENTA

! dwm 状态栏颜色（dwmbar）
dwm.col_status_fg:      WHITE
dwm.col_status_bg:      BG
dwm.col_status_border:  BG

! dwm 窗口标题区颜色（标题栏）
dwm.col_title_fg:       FG
dwm.col_title_bg:       BG
dwm.col_title_border:   BLACK

! dwm 窗口标题区颜色 - 选中状态
dwm.col_titlesel_fg:    FG
dwm.col_titlesel_bg:    BG
dwm.col_titlesel_border: BG

! dwm Tag 标签下划线颜色
dwm.col_tagunderline:   MAGENTA_LIGHT
dwm.tagunderline: 0
dwm.tagicons: 1

! slstatus 状态栏颜色
slstatus.sep:   BLACK
slstatus.net:   WHITE
slstatus.cpu:   WHITE
slstatus.ram:   WHITE
slstatus.gpu:   WHITE
slstatus.temp:  WHITE
slstatus.kbd:   RED
slstatus.swap:  WHITE
slstatus.time:  WHITE

! slock 锁屏颜色
slock.init:     BG
slock.input:    MAGENTA_DARK
slock.fail:     RED
slock.text:     WHITE

! wallpick 配色
wallpick.background: BG
wallpick.borderSelected: MAGENTA

! sysmenu 配色
sysmenu.background: BG
sysmenu.foreground: FG
sysmenu.backgroundSelected: MAGENTA
sysmenu.foregroundSelected: WHITER
sysmenu.backgroundHover: BORDER
sysmenu.countdown: 5
