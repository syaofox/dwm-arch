[Default Applications]
x-scheme-handler/http=chromium.desktop
x-scheme-handler/https=chromium.desktop
x-scheme-handler/about=chromium.desktop

# 图片
image/jpeg=gthumb.desktop
image/png=gthumb.desktop
image/gif=gthumb.desktop
image/bmp=gthumb.desktop
image/webp=gthumb.desktop
image/tiff=gthumb.desktop
image/svg+xml=gthumb.desktop
image/avif=gthumb.desktop
image/heic=gthumb.desktop
image/heif=gthumb.desktop
image/vnd.microsoft.icon=gthumb.desktop

# 文本/代码
text/plain=code.desktop
text/html=code.desktop
text/markdown=code.desktop
text/x-shellscript=code.desktop
text/x-python=code.desktop
text/x-json=code.desktop
application/json=code.desktop
text/x-lua=code.desktop
text/x-yaml=code.desktop
application/x-yaml=code.desktop
text/x-toml=code.desktop
application/toml=code.desktop
text/javascript=code.desktop
application/javascript=code.desktop
text/x-typescript=code.desktop
text/x-go=code.desktop
text/x-rust=code.desktop
text/x-csrc=code.desktop
text/x-chdr=code.desktop
text/x-c++src=code.desktop
text/x-c++hdr=code.desktop
text/css=code.desktop
text/x-diff=code.desktop
application/x-httpd-php=code.desktop
application/xml=code.desktop
text/xml=code.desktop

# 其他文档
application/pdf=chromium.desktop

# 媒体
video/*=mpv.desktop
audio/*=mpv.desktop
