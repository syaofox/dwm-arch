[Default Applications]
x-scheme-handler/http=chromium.desktop
x-scheme-handler/https=chromium.desktop
x-scheme-handler/about=chromium.desktop

# 图片
image/jpeg=org.gnome.gThumb.desktop
image/png=org.gnome.gThumb.desktop
image/gif=org.gnome.gThumb.desktop
image/bmp=org.gnome.gThumb.desktop
image/webp=org.gnome.gThumb.desktop
image/tiff=org.gnome.gThumb.desktop
image/svg+xml=org.gnome.gThumb.desktop
image/avif=org.gnome.gThumb.desktop
image/heic=org.gnome.gThumb.desktop
image/heif=org.gnome.gThumb.desktop
image/vnd.microsoft.icon=org.gnome.gThumb.desktop

# 文本/代码
text/plain=code-oss.desktop
text/html=code-oss.desktop
text/markdown=code-oss.desktop
text/x-shellscript=code-oss.desktop
text/x-python=code-oss.desktop
text/x-json=code-oss.desktop
application/json=code-oss.desktop
text/x-lua=code-oss.desktop
text/x-yaml=code-oss.desktop
application/x-yaml=code-oss.desktop
text/x-toml=code-oss.desktop
application/toml=code-oss.desktop
text/javascript=code-oss.desktop
application/javascript=code-oss.desktop
text/x-typescript=code-oss.desktop
text/x-go=code-oss.desktop
text/x-rust=code-oss.desktop
text/x-csrc=code-oss.desktop
text/x-chdr=code-oss.desktop
text/x-c++src=code-oss.desktop
text/x-c++hdr=code-oss.desktop
text/css=code-oss.desktop
text/x-diff=code-oss.desktop
application/x-httpd-php=code-oss.desktop
application/xml=code-oss.desktop
text/xml=code-oss.desktop

# 其他文档
application/pdf=chromium.desktop

# 媒体
video/*=mpv.desktop
audio/*=mpv.desktop
