/*
 * GTK Colors (Light)
 * Generated by dwm-arch theme system
 */

@define-color destructive_bg_color {{ GTK_ERROR_BG }};
@define-color destructive_fg_color {{ GTK_ERROR_FG }};
@define-color error_bg_color {{ GTK_ERROR_BG }};
@define-color error_fg_color {{ GTK_ERROR_FG }};
@define-color success_bg_color {{ GTK_SUCCESS_BG }};
@define-color success_fg_color {{ GTK_SUCCESS_FG }};
@define-color warning_bg_color {{ GTK_WARNING_BG }};
@define-color warning_fg_color {{ GTK_WARNING_FG }};
@define-color accent_fg_color {{ GTK_ACCENT_FG_LIGHT }};
@define-color accent_bg_color {{ GTK_ACCENT_BG_LIGHT }};
@define-color window_bg_color {{ GTK_WIN_BG_LIGHT }};
@define-color window_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color view_bg_color {{ GTK_WIN_BG_LIGHT }};
@define-color view_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color headerbar_bg_color {{ GTK_WIN_BG_LIGHT }};
@define-color headerbar_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color sidebar_bg_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color sidebar_fg_color {{ GTK_SURFACE_FG_LIGHT }};
@define-color secondary_sidebar_bg_color {{ GTK_WIN_BG_LIGHT }};
@define-color secondary_sidebar_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color card_bg_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color card_fg_color {{ GTK_SURFACE_FG_LIGHT }};
@define-color overview_bg_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color overview_fg_color {{ GTK_SURFACE_FG_LIGHT }};
@define-color popover_bg_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color popover_fg_color {{ GTK_SURFACE_FG_LIGHT }};
@define-color dialog_bg_color {{ GTK_WIN_BG_LIGHT }};
@define-color dialog_fg_color {{ GTK_WIN_FG_LIGHT }};

@define-color headerbar_backdrop_color {{ GTK_WIN_BG_LIGHT }};
@define-color sidebar_backdrop_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color theme_unfocused_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color theme_unfocused_text_color {{ GTK_WIN_FG_LIGHT }};
@define-color theme_unfocused_bg_color {{ GTK_WIN_BG_LIGHT }};
@define-color theme_unfocused_base_color {{ GTK_WIN_BG_LIGHT }};
@define-color theme_unfocused_selected_bg_color {{ GTK_ACCENT_BG_LIGHT }};
@define-color theme_unfocused_selected_fg_color {{ GTK_ACCENT_FG_LIGHT }};

/* Mint-Y / GTK3 backward compatibility */
@define-color theme_bg_color {{ GTK_WIN_BG_LIGHT }};
@define-color theme_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color theme_base_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color theme_text_color {{ GTK_WIN_FG_LIGHT }};
@define-color theme_selected_bg_color {{ GTK_ACCENT_BG_LIGHT }};
@define-color theme_selected_fg_color {{ GTK_ACCENT_FG_LIGHT }};
@define-color theme_tooltip_bg_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color theme_tooltip_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color theme_unfocused_base_color {{ GTK_WIN_BG_LIGHT }};
@define-color wm_bg {{ GTK_WIN_BG_LIGHT }};
@define-color wm_fg {{ GTK_WIN_FG_LIGHT }};
@define-color wm_unfocused_bg {{ GTK_WIN_BG_LIGHT }};
@define-color wm_unfocused_fg {{ GTK_WIN_FG_LIGHT }};
@define-color borders {{ GTK_SURFACE_BG_LIGHT }};
@define-color borders_edge {{ GTK_WIN_BG_LIGHT }};

/* GTK3 widget overrides for themes with hardcoded colors */
.background, window {
  background-color: @window_bg_color;
  color: @window_fg_color;
}
headerbar, .titlebar {
  background-color: @headerbar_bg_color;
  color: @headerbar_fg_color;
}
.sidebar, .sidebar.view,
.sidebar .view, .sidebar row {
  background-color: @sidebar_bg_color;
  color: @sidebar_fg_color;
}
.view, .view text,
textview text, treeview {
  background-color: @view_bg_color;
  color: @view_fg_color;
}
entry {
  background-color: @theme_base_color;
  color: @theme_text_color;
}
button {
  background-color: @card_bg_color;
  color: @window_fg_color;
  border-color: @borders;
}
button:hover {
  background-color: shade(@card_bg_color, 0.9);
}
button:active {
  background-color: shade(@card_bg_color, 0.8);
}
button:checked {
  background-color: shade(@card_bg_color, 0.85);
}
popover.background {
  background-color: @popover_bg_color;
  color: @popover_fg_color;
}
tooltip.background {
  background-color: @theme_tooltip_bg_color;
  color: @theme_tooltip_fg_color;
}

/* Selection overrides */
selection,
.view:selected,
row:selected,
entry:selected {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
}

/* Menubar and toolbar */
menubar, .menubar {
  background-color: @headerbar_bg_color;
  color: @headerbar_fg_color;
}
menu, .menu {
  background-color: @popover_bg_color;
  color: @popover_fg_color;
}
menuitem {
  background-color: transparent;
  color: @popover_fg_color;
}
menuitem:hover {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
}
toolbar, .toolbar {
  background-color: @card_bg_color;
  color: @window_fg_color;
  border-color: @borders;
}

/* Statusbar / bottom bar */
statusbar, .statusbar,
.bottom-bar, .bottom-bar button {
  background-color: @headerbar_bg_color;
  color: @headerbar_fg_color;
}

/* Paned (split pane) */
paned, .paned {
  background-color: @window_bg_color;
  color: @window_fg_color;
}

/* Labels - ensure text inheritance */
label {
  color: @window_fg_color;
}
button label {
  color: inherit;
}

/* Action bar and info bar */
actionbar, .actionbar {
  background-color: @card_bg_color;
  color: @window_fg_color;
  border-color: @borders;
}
infobar, .info {
  background-color: @card_bg_color;
  color: @window_fg_color;
  border-color: @borders;
}

/* Places sidebar (Nemo specific) */
placessidebar, .placessidebar {
  background-color: @sidebar_bg_color;
  color: @sidebar_fg_color;
}

/* Title buttons */
.titlebutton {
  color: @window_fg_color;
}

/* Button variants */
button.suggested-action {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
  border-color: @accent_bg_color;
}
button.suggested-action:hover {
  background-color: shade(@accent_bg_color, 0.85);
}
button.destructive-action {
  background-color: @destructive_bg_color;
  color: @destructive_fg_color;
  border-color: @destructive_bg_color;
}
button.destructive-action:hover {
  background-color: shade(@destructive_bg_color, 0.85);
}

/* Scrollbar */
scrollbar {
  background-color: @window_bg_color;
}
scrollbar trough {
  background-color: transparent;
  border: none;
}
scrollbar slider {
  background-color: mix(@window_fg_color, @window_bg_color, 0.85);
  border: none;
  min-width: 6px;
  min-height: 6px;
  border-radius: 3px;
}
scrollbar slider:hover {
  background-color: mix(@window_fg_color, @window_bg_color, 0.75);
}
scrollbar slider:active {
  background-color: @accent_bg_color;
}
scrollbar .button {
  background-color: transparent;
  color: @window_fg_color;
  border: none;
}

/* Switch */
switch {
  background-color: mix(@window_fg_color, @window_bg_color, 0.7);
  border: none;
  border-radius: 12px;
}
switch:checked {
  background-color: @accent_bg_color;
}
switch slider {
  background-color: @card_bg_color;
  border: 1px solid mix(@window_fg_color, @window_bg_color, 0.7);
  border-radius: 100%;
  min-width: 18px;
  min-height: 18px;
}
switch:checked slider {
  border-color: @accent_bg_color;
}

/* Scale */
scale trough {
  background-color: mix(@window_fg_color, @window_bg_color, 0.85);
  border: none;
  border-radius: 3px;
  min-height: 6px;
}
scale highlight {
  background-color: @accent_bg_color;
  border: none;
  border-radius: 3px;
}
scale slider {
  background-color: @card_bg_color;
  border: 1px solid mix(@window_fg_color, @window_bg_color, 0.7);
  border-radius: 100%;
  min-width: 14px;
  min-height: 14px;
}
scale slider:hover {
  background-color: @window_bg_color;
}
scale slider:active {
  border-color: @accent_bg_color;
}

/* Progressbar */
progressbar trough {
  background-color: mix(@window_fg_color, @window_bg_color, 0.9);
  border: none;
  border-radius: 3px;
  min-height: 8px;
}
progressbar progress {
  background-color: @accent_bg_color;
  border: none;
  border-radius: 3px;
}

/* Notebook / Tabs */
notebook {
  background-color: @window_bg_color;
  border: none;
}
notebook > header {
  background-color: mix(@window_fg_color, @window_bg_color, 0.95);
  border: none;
}
notebook tab {
  background-color: mix(@window_fg_color, @window_bg_color, 0.92);
  color: @window_fg_color;
  border: none;
  padding: 6px 12px;
}
notebook tab:checked {
  background-color: @window_bg_color;
  color: @window_fg_color;
}
notebook tab:hover {
  background-color: mix(@window_fg_color, @window_bg_color, 0.85);
}

/* Combobox */
combobox {
  background-color: @theme_base_color;
  color: @theme_text_color;
}
combobox .arrow {
  color: @window_fg_color;
}
combobox button {
  background-color: @theme_base_color;
  color: @theme_text_color;
}

/* Spinbutton */
spinbutton {
  background-color: @theme_base_color;
  color: @theme_text_color;
}
spinbutton button {
  background-color: @card_bg_color;
  color: @window_fg_color;
}

/* List & List Row */
list {
  background-color: @window_bg_color;
  color: @window_fg_color;
  border: none;
}
row {
  background-color: transparent;
  color: @window_fg_color;
}
row:hover {
  background-color: mix(@window_fg_color, @window_bg_color, 0.95);
}
row:selected {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
}

/* Treeview Column Header */
treeview column-header button {
  background-color: mix(@window_fg_color, @window_bg_color, 0.92);
  color: @window_fg_color;
  border: none;
  padding: 4px 8px;
}
treeview column-header button:hover {
  background-color: mix(@window_fg_color, @window_bg_color, 0.85);
}

/* Frame */
frame {
  border: 1px solid mix(@window_fg_color, @window_bg_color, 0.85);
}
frame > border {
  border: none;
}

/* Separator */
separator {
  background-color: mix(@window_fg_color, @window_bg_color, 0.88);
  min-width: 1px;
  min-height: 1px;
}
sidebar separator,
.sidebar separator {
  background-color: mix(@window_fg_color, @window_bg_color, 0.88);
}

/* Dialog */
dialog, messagedialog {
  background-color: @window_bg_color;
  color: @window_fg_color;
}
.dialog-action-area button {
  background-color: @card_bg_color;
  color: @window_fg_color;
}
.dialog-action-area button:hover {
  background-color: mix(@window_fg_color, @window_bg_color, 0.95);
}

/* Expander */
expander {
  color: @window_fg_color;
}

/* Calendar */
calendar {
  background-color: @window_bg_color;
  color: @window_fg_color;
  border: 1px solid mix(@window_fg_color, @window_bg_color, 0.85);
}
calendar:selected {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
}
calendar.header {
  background-color: mix(@window_fg_color, @window_bg_color, 0.95);
  color: @window_fg_color;
}
calendar.button {
  background-color: transparent;
  color: @window_fg_color;
}
calendar.highlight {
  color: @accent_bg_color;
}

/* OSD */
.osd, .osd .view {
  background-color: @window_bg_color;
  color: @window_fg_color;
}
