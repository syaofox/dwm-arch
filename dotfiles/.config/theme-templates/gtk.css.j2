/* Mint-Y / GTK3 backward compatibility */
@define-color theme_bg_color {{ GTK_WIN_BG_LIGHT }};
@define-color theme_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color theme_base_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color theme_text_color {{ GTK_WIN_FG_LIGHT }};
@define-color theme_selected_bg_color {{ GTK_ACCENT_BG_LIGHT }};
@define-color theme_selected_fg_color {{ GTK_ACCENT_FG_LIGHT }};
@define-color theme_tooltip_bg_color {{ GTK_SURFACE_BG_LIGHT }};
@define-color theme_tooltip_fg_color {{ GTK_WIN_FG_LIGHT }};
@define-color theme_unfocused_base_color {{ GTK_WIN_BG_LIGHT }};
@define-color wm_bg {{ GTK_WIN_BG_LIGHT }};
@define-color wm_fg {{ GTK_WIN_FG_LIGHT }};
@define-color wm_unfocused_bg {{ GTK_WIN_BG_LIGHT }};
@define-color wm_unfocused_fg {{ GTK_WIN_FG_LIGHT }};
@define-color borders {{ GTK_SURFACE_BG_LIGHT }};
@define-color borders_edge {{ GTK_WIN_BG_LIGHT }};

/* GTK3 widget overrides for themes with hardcoded colors */
.background, window {
  background-color: @window_bg_color;
  color: @window_fg_color;
}
headerbar, .titlebar {
  background-color: @headerbar_bg_color;
  color: @headerbar_fg_color;
}
.sidebar, .sidebar.view,
.sidebar .view, .sidebar row {
  background-color: @sidebar_bg_color;
  color: @sidebar_fg_color;
}
.view, .view text,
textview text, treeview {
  background-color: @view_bg_color;
  color: @view_fg_color;
}
entry {
  background-color: @theme_base_color;
  color: @theme_text_color;
}
button {
  background-color: @card_bg_color;
  color: @window_fg_color;
  border-color: @borders;
}
button:hover {
  background-color: shade(@card_bg_color, 0.9);
}
button:active {
  background-color: shade(@card_bg_color, 0.8);
}
button:checked {
  background-color: shade(@card_bg_color, 0.85);
}
popover.background {
  background-color: @popover_bg_color;
  color: @popover_fg_color;
}
tooltip.background {
  background-color: @theme_tooltip_bg_color;
  color: @theme_tooltip_fg_color;
}

/* Selection overrides */
selection,
.view:selected,
row:selected,
entry:selected {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
}

/* Menubar and toolbar */
menubar, .menubar {
  background-color: @headerbar_bg_color;
  color: @headerbar_fg_color;
}
menu, .menu {
  background-color: @popover_bg_color;
  color: @popover_fg_color;
}
menuitem {
  background-color: transparent;
  color: @popover_fg_color;
}
menuitem:hover {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
}
toolbar, .toolbar {
  background-color: @card_bg_color;
  color: @window_fg_color;
  border-color: @borders;
}

/* Statusbar / bottom bar */
statusbar, .statusbar,
.bottom-bar, .bottom-bar button {
  background-color: @headerbar_bg_color;
  color: @headerbar_fg_color;
}

/* Paned (split pane) */
paned, .paned {
  background-color: @window_bg_color;
  color: @window_fg_color;
}

/* Labels - ensure text inheritance */
label {
  color: @window_fg_color;
}
button label {
  color: inherit;
}

/* Action bar and info bar */
actionbar, .actionbar {
  background-color: @card_bg_color;
  color: @window_fg_color;
  border-color: @borders;
}
infobar, .info {
  background-color: @card_bg_color;
  color: @window_fg_color;
  border-color: @borders;
}

/* Places sidebar (Nemo specific) */
placessidebar, .placessidebar {
  background-color: @sidebar_bg_color;
  color: @sidebar_fg_color;
}

/* Title buttons */
.titlebutton {
  color: @window_fg_color;
}

/* Button variants */
button.suggested-action {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
  border-color: @accent_bg_color;
}
button.suggested-action:hover {
  background-color: shade(@accent_bg_color, 0.85);
}
button.destructive-action {
  background-color: @destructive_bg_color;
  color: @destructive_fg_color;
  border-color: @destructive_bg_color;
}
button.destructive-action:hover {
  background-color: shade(@destructive_bg_color, 0.85);
}
